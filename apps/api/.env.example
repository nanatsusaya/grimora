# apps/api runtime config — copy to `apps/api/.env` (git-ignored) and fill in.
# See docs/ops/supabase-setup.md for where these come from. Never commit real values.

# Supabase project URL (not a secret — present in every client request).
PROJECT_URL=https://<your-project-ref>.supabase.co

# Browser-safe PUBLISHABLE key (sb_publishable_...) — used as GoTrue's `apikey`. NOT the secret key.
PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxx

# SECRET. Direct Postgres connection string (Supabase → Project Settings → Database → Connection string
# → "Direct connection"). Used by the sync event store + scripts/db-migrate.ts (#107). Percent-encode the
# password if it has special characters. Keep in the git-ignored .env only — never commit.
DATABASE_URL=postgresql://postgres:YOUR-DB-PASSWORD@db.<your-project-ref>.supabase.co:5432/postgres

# Optional. Relax the refresh cookie's `Secure` flag for a local http://localhost dev run
# (default is secure). Set to false only for local development, never in production.
# COOKIE_SECURE=false

# Optional. HTTP listen port for the local dev server (default 3001).
# PORT=3001

# Optional — ONLY for scripts/auth-smoke.ts (the live Supabase verification). A pre-confirmed dev
# test user. Keep in the git-ignored .env; these are dev throwaway creds, never real/production data.
# SMOKE_EMAIL=dev@grimora.test
# SMOKE_PASSWORD=your-dev-test-user-password
