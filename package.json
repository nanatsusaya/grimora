{
  "name": "grimora",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Grimora — engine-agnostic tabletop RPG platform (DSA5 as the first rule-system plugin).",
  "license": "MIT",
  "packageManager": "bun@1.3.14",
  "engines": {
    "node": ">=20",
    "bun": ">=1.3"
  },
  "workspaces": [
    "apps/*",
    "packages/*",
    "plugins/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "serve": "turbo run serve",
    "build": "turbo run build",
    "test": "turbo run test",
    "test:coverage": "turbo run test -- --coverage",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "turbo run typecheck",
    "arch": "bun test scripts/arch",
    "check": "bun run lint && bun run typecheck && bun run arch && bun run test && bun run build",
    "clear": "bunx rimraf@6 --glob node_modules .turbo \"apps/*/dist\" \"packages/*/dist\" \"plugins/*/dist\" \"apps/*/node_modules\" \"packages/*/node_modules\" \"plugins/*/node_modules\"",
    "refresh": "bun run clear && bun install"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.0",
    "dependency-cruiser": "^18.0.0",
    "ts-morph": "^28.0.0",
    "turbo": "^2.0.0",
    "typescript": "^6.0.3"
  }
}
