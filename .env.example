# Grimora — environment template. Copy to .env and fill in. NEVER commit .env.
# Phase 0-2 run fully local (offline-first) and need NONE of the cloud values below.

# --- Local stack (docker-compose: Postgres + MinIO) ---
DATABASE_URL="postgresql://grimora:grimora@localhost:5432/grimora"
S3_ENDPOINT="http://localhost:9000"
S3_ACCESS_KEY="grimora"
S3_SECRET_KEY="grimora-dev-secret"
S3_BUCKET="grimora-assets"

# --- Supabase (cloud sync, Phase 3+; EU region) ---
SUPABASE_URL=""
SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# --- AI providers (multi-provider; at least one for the optional AI chat) ---
# No-consent default = local Ollama (needs no key, fully local). External providers (Anthropic Claude /
# OpenAI) are opt-in only after explicit user consent (ADR 0008).
AI_PROVIDER="ollama"
ANTHROPIC_API_KEY=""
OPENAI_API_KEY=""
OLLAMA_BASE_URL="http://localhost:11434"
